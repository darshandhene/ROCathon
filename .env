# Required for OpenAI embeddings (recommended)
OPENAI_API_KEY=sk-proj-o-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Set to "local" to use @xenova/transformers instead of OpenAI(Recommended)
EMBEDDING_PROVIDER=openai

# Supabase connection string (or local Docker postgres)
DATABASE_URL= postgresql://postgres.xxxxxxxxxxxxxxxx:password@aws-1-us-east-1.pooler.supabase.com:6543/postgres 
